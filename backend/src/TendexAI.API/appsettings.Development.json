{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information",
      "TendexAI.Infrastructure.Messaging": "Debug"
    }
  },
  "ConnectionStrings": {
    "MasterPlatform": "Server=localhost,1433;Database=master_platform;User Id=sa;Password=${MSSQL_SA_PASSWORD};TrustServerCertificate=True;Encrypt=True;"
