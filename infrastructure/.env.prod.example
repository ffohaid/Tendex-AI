# =============================================================================
# Tendex AI - Production Environment Variables Template
# =============================================================================
# Copy this file to .env.prod and fill in REAL production values.
#
#   cp .env.prod.example .env.prod
#
# CRITICAL: Never commit .env.prod to version control.
#           All passwords must be strong, unique, and randomly generated.
#           Use: openssl rand -base64 32 | tr -d '=/+' | head -c 32
# =============================================================================

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=tendex-prod
DOMAIN=tendex.example.com
ACME_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# SQL Server 2022
# -----------------------------------------------------------------------------
# SA password MUST meet complexity requirements:
#   - Minimum 16 characters
#   - Uppercase, lowercase, digits, and special characters
MSSQL_SA_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
MSSQL_PID=Developer
MSSQL_MEMORY_LIMIT_MB=4096

# -----------------------------------------------------------------------------
# Redis 7
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
REDIS_MAX_MEMORY=1024mb

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_USER=tendex_prod_admin
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
RABBITMQ_VHOST=tendex

# -----------------------------------------------------------------------------
# MinIO (S3-Compatible Object Storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=tendex_minio_prod
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# -----------------------------------------------------------------------------
# Qdrant (Vector Database)
# -----------------------------------------------------------------------------
QDRANT_API_KEY=CHANGE_ME_STRONG_API_KEY_HERE

# -----------------------------------------------------------------------------
# Elasticsearch
# -----------------------------------------------------------------------------
ELASTIC_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# -----------------------------------------------------------------------------
# Backend API (.NET)
# -----------------------------------------------------------------------------
# Connection string uses container hostname (tendex-sqlserver)
ASPNETCORE_ENVIRONMENT=Production
CONNECTION_STRING=Server=tendex-sqlserver;Database=master_platform;User Id=sa;Password=CHANGE_ME_STRONG_PASSWORD_HERE;TrustServerCertificate=true;MultipleActiveResultSets=true
JWT_SECRET_KEY=CHANGE_ME_MINIMUM_64_CHARS_RANDOM_SECRET_KEY_HERE_MUST_BE_VERY_LONG
JWT_ISSUER=https://tendex.example.com
JWT_AUDIENCE=tendex-api

# Redis connection for backend
REDIS_CONNECTION=tendex-redis:6379,password=CHANGE_ME_STRONG_PASSWORD_HERE,abortConnect=false

# RabbitMQ connection for backend
RABBITMQ_CONNECTION=amqp://tendex_prod_admin:CHANGE_ME_STRONG_PASSWORD_HERE@tendex-rabbitmq:5672/tendex

# MinIO connection for backend
MINIO_ENDPOINT=tendex-minio:9000
MINIO_ACCESS_KEY=tendex_minio_prod
MINIO_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD_HERE
MINIO_USE_SSL=false

# Qdrant connection for backend
QDRANT_ENDPOINT=http://tendex-qdrant:6333
QDRANT_COLLECTION_PREFIX=tendex_prod

# Elasticsearch connection for backend
ELASTICSEARCH_URL=http://tendex-elasticsearch:9200

# -----------------------------------------------------------------------------
# Frontend Build Args
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=https://tendex.example.com/api
VITE_APP_TITLE=Tendex AI

# -----------------------------------------------------------------------------
# Grafana (Monitoring)
# -----------------------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
