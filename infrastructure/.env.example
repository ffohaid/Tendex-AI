# =============================================================================
# Tendex AI - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
#
#   cp .env.example .env
#
# WARNING: Never commit the .env file to version control.
#          Real passwords and API keys must remain local only.
# =============================================================================

# -----------------------------------------------------------------------------
# SQL Server 2022
# -----------------------------------------------------------------------------
# SA password must meet SQL Server complexity requirements:
#   - At least 8 characters
#   - Includes uppercase, lowercase, digits, and special characters
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
MSSQL_PID=Developer
MSSQL_MEMORY_LIMIT_MB=2048
MSSQL_HOST_PORT=1433

# -----------------------------------------------------------------------------
# Redis 7
# -----------------------------------------------------------------------------
REDIS_PASSWORD=YourRedisP@ssw0rd
REDIS_HOST_PORT=6379
REDIS_MAX_MEMORY=512mb

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_USER=tendex_admin
RABBITMQ_PASSWORD=YourRabbitMQ!Pass
RABBITMQ_VHOST=tendex
RABBITMQ_HOST_PORT=5672
RABBITMQ_MGMT_PORT=15672

# -----------------------------------------------------------------------------
# MinIO (S3-Compatible Object Storage)
# -----------------------------------------------------------------------------
# Root user must be at least 3 characters; root password at least 8 characters.
MINIO_ROOT_USER=tendex_minio_admin
MINIO_ROOT_PASSWORD=YourMinIO!Passw0rd
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Qdrant (Vector Database)
# -----------------------------------------------------------------------------
QDRANT_API_KEY=YourQdrantAp1K3y
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
